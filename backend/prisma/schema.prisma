generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  cats      Cat[]
}

model Cat {
  id          String     @id @default(uuid())
  name        String
  breed       String
  color       String
  description String?
  image       String
  latitude    Float
  longitude   Float
  createdAt   DateTime   @default(now())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  photos      CatPhoto[]
}

model CatPhoto {
  id            String   @id @default(uuid())
  catId         String
  cat           Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  filePath      String
  embeddingJson String
  latitude      Float?
  longitude     Float?
  createdAt     DateTime @default(now())
}
